// Content Graph Phase 1 Enums
// Per docs/specs/CONTENT-GRAPH-DATA-MODEL.md

enum CgSurfaceType {
  website
  wiki
  blog
  x
  youtube
}

enum CgPublishingState {
  draft
  published
  archived
}

enum CgPageRole {
  primary
  supporting
  reviewed
  compared
  navigation
}

enum CgLinkRole {
  hub
  support
  navigation
}

// =============================================================================
// Project — Multi-project scoping
// Every domain entity belongs to exactly one project.
// =============================================================================

model Project {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  slug           String   @unique
  description    String?
  lifecycleState String?  @default("created")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Reverse relations
  entities           Entity[]
  sourceItems        SourceItem[]
  sourceFeeds        SourceFeed[]
  entityRelations    EntityRelation[]
  eventLogs          EventLog[]
  videos             Video[]
  distributionEvents DistributionEvent[]
  metricSnapshots    MetricSnapshot[]
  draftArtifacts     DraftArtifact[]
  searchPerformanceRecords SearchPerformance[]
  quotableBlocks     QuotableBlock[]
  keywordTargets     KeywordTarget[]
  serpSnapshots      SERPSnapshot[]
  // Content Graph Phase 1
  cgSurfaces         CgSurface[]
  cgSites            CgSite[]
  cgPages            CgPage[]
  cgContentArchetypes CgContentArchetype[]
  cgTopics           CgTopic[]
  cgEntities         CgEntity[]
  cgInternalLinks    CgInternalLink[]
  cgSchemaUsages     CgSchemaUsage[]
  cgPageTopics       CgPageTopic[]
  cgPageEntities     CgPageEntity[]
}

// =============================================================================
// Source & Capture Entities
// =============================================================================

model SourceItem {
  id             String           @id @default(uuid()) @db.Uuid
  sourceType     SourceType
  platform       Platform         @default(other)
  url            String           @unique
  capturedAt     DateTime         @default(now())
  capturedBy     CapturedBy       @default(human)
  contentHash    String
  snapshotRef    String?
  snapshotMime   String?
  snapshotBytes  Int?
  operatorIntent String
  notes          String?
  status         SourceItemStatus @default(ingested)
  archivedAt     DateTime?

  sourceFeedId   String?          @db.Uuid
  sourceFeed     SourceFeed?      @relation(fields: [sourceFeedId], references: [id], onDelete: SetNull)

  projectId      String           @db.Uuid
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([projectId, status, capturedAt])
  @@index([sourceType, platform])
}

model SourceFeed {
  id            String     @id @default(uuid()) @db.Uuid
  name          String
  feedUrl       String     @unique
  platform      Platform
  platformLabel String?
  isActive      Boolean    @default(true)

  projectId     String     @db.Uuid
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Restrict)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sourceItems   SourceItem[]

  @@index([projectId])
}

// =============================================================================
// Content Entities — Unified table for guides, concepts, projects, news
// Using a single table to simplify polymorphic relationships and querying.
// entityType discriminates the kind.
// =============================================================================

model Entity {
  id                String            @id @default(uuid()) @db.Uuid
  entityType        ContentEntityType
  title             String
  slug              String
  summary           String?
  difficulty        Difficulty?
  conceptKind       ConceptKind?      // only for entityType=concept
  comparisonTargets String[]          @db.Uuid @default([]) // only when conceptKind=comparison
  repoUrl           String?           // only for entityType=project
  repoDefaultBranch String?
  license           String?
  status            EntityStatus      @default(draft)
  canonicalUrl      String?
  contentRef        String?
  publishedAt       DateTime?
  archivedAt        DateTime?
  lastVerifiedAt    DateTime?         // Content freshness tracking (SEO)

  projectId         String            @db.Uuid
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  distributionEvents         DistributionEvent[]
  metricSnapshots            MetricSnapshot[]
  quotableBlocks             QuotableBlock[]
  searchPerformanceRecords   SearchPerformance[]

  @@unique([projectId, entityType, slug])
  @@index([projectId, entityType, status, createdAt])
}

// =============================================================================
// Relationship Graph — from DB-ARCHITECTURE-PLAN.md
// =============================================================================

model EntityRelation {
  id             String       @id @default(uuid()) @db.Uuid
  fromEntityType EntityType
  fromEntityId   String       @db.Uuid
  toEntityType   EntityType
  toEntityId     String       @db.Uuid
  relationType   RelationType
  notes          String?

  projectId      String       @db.Uuid
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)

  createdAt      DateTime     @default(now())

  @@unique([projectId, fromEntityType, fromEntityId, relationType, toEntityType, toEntityId])
  @@index([projectId, fromEntityId])
  @@index([projectId, toEntityId])
}

// =============================================================================
// Event Log — append-only, from DB-ARCHITECTURE-PLAN.md
// projectId added directly to avoid joins for project-scoped audit queries.
// Invariant: entityType always identifies the table that entityId references.
// =============================================================================

model EventLog {
  id         String    @id @default(uuid()) @db.Uuid
  eventType  EventType
  entityType EntityType
  entityId   String    @db.Uuid
  actor      ActorType
  details    Json?

  projectId  String    @db.Uuid
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)

  timestamp  DateTime  @default(now())

  @@index([projectId, timestamp, id])
  @@index([entityType, entityId, timestamp])
}

// =============================================================================
// Distribution Entities — Video
// Per DB-ARCHITECTURE-PLAN.md: Video spec
// =============================================================================

model Video {
  id                String            @id @default(uuid()) @db.Uuid
  platform          Platform
  externalUrl       String
  status            EntityStatus      @default(draft)
  publishedAt       DateTime?
  archivedAt        DateTime?
  primaryEntityType ContentEntityType
  primaryEntityId   String            @db.Uuid

  projectId         String            @db.Uuid
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([projectId, primaryEntityType, primaryEntityId])
  @@index([status])
  @@index([platform])
}

// =============================================================================
// Draft Artifacts — scaffolding only, non-canonical
// Per ROADMAP.md Phase 1 Draft System requirements
// SEO additions: schemaVersion, source, contentHash per SEO-SCHEMA-MIGRATION-PLAN.md
// =============================================================================

model DraftArtifact {
  id           String              @id @default(uuid()) @db.Uuid
  kind         DraftArtifactKind
  status       DraftArtifactStatus @default(draft)
  content      String
  sourceItemId String?             @db.Uuid
  entityId     String?             @db.Uuid
  createdBy    ActorType
  llmModel     String?
  llmMeta      Json?
  expiresAt    DateTime
  deletedAt    DateTime?
  schemaVersion String?            // Versioned contract for structured JSON content (e.g., seo.keyword_research.v1)
  source       String?             // Data provider identifier (e.g., dataforseo, gsc, manual)
  contentHash  String?             // SHA256 for deduplication. Application-enforced, not DB-unique.

  projectId    String              @db.Uuid
  project      Project             @relation(fields: [projectId], references: [id], onDelete: Restrict)

  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([projectId, kind, status])
  @@index([sourceItemId, kind])
  @@index([expiresAt, deletedAt])
  @@index([contentHash])
}

// =============================================================================
// Distribution Entities — DistributionEvent
// Per PHASE-1-SLICE-DISTRIBUTION-AND-METRICS.md
// =============================================================================

model DistributionEvent {
  id                String            @id @default(uuid()) @db.Uuid
  platform          Platform
  externalUrl       String
  status            EntityStatus      @default(draft)
  publishedAt       DateTime?
  archivedAt        DateTime?
  primaryEntityType ContentEntityType
  primaryEntityId   String            @db.Uuid

  projectId         String            @db.Uuid
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  primaryEntity     Entity?           @relation(fields: [primaryEntityId], references: [id], onDelete: Restrict)

  @@index([projectId, primaryEntityType, primaryEntityId])
  @@index([status])
  @@index([platform])
}

// =============================================================================
// Metrics — MetricSnapshot
// Per PHASE-1-SLICE-DISTRIBUTION-AND-METRICS.md
// SEO change: value Int → Float per SEO-SCHEMA-MIGRATION-PLAN.md
// =============================================================================

model MetricSnapshot {
  id          String            @id @default(uuid()) @db.Uuid
  metricType  MetricType
  value       Float
  platform    Platform
  capturedAt  DateTime          @default(now())
  entityType  ContentEntityType
  entityId    String            @db.Uuid
  notes       String?

  projectId   String            @db.Uuid
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)

  createdAt   DateTime          @default(now())

  // Relations
  entity      Entity?           @relation(fields: [entityId], references: [id], onDelete: Restrict)

  @@index([projectId, metricType, capturedAt])
  @@index([projectId, entityType, entityId, capturedAt])
}

// =============================================================================
// Search Performance — GSC query × page × date-range analytics
// Per SEO-SCHEMA-MIGRATION-PLAN.md, SEO-RECORDING-SPEC.md
// Source of truth for search performance data. GSC only.
// =============================================================================

model SearchPerformance {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @db.Uuid
  entityId    String?   @db.Uuid
  pageUrl     String
  query       String
  impressions Int
  clicks      Int
  ctr         Float
  avgPosition Float
  dateStart   DateTime
  dateEnd     DateTime
  capturedAt  DateTime  @default(now())

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  entity      Entity?   @relation(fields: [entityId], references: [id], onDelete: Restrict)

  @@unique([projectId, query, pageUrl, dateStart, dateEnd])
  @@index([projectId, capturedAt])
  @@index([projectId, pageUrl, dateStart])
  @@index([projectId, query, dateStart])
}

// =============================================================================
// Quotable Blocks — Canonical structured citation assets for GEO optimization
// Per SEO-SCHEMA-MIGRATION-PLAN.md, SEO-RECORDING-SPEC.md
// NOT a DraftArtifact. These are verified, human-approved citation units.
// =============================================================================

model QuotableBlock {
  id              String    @id @default(uuid()) @db.Uuid
  projectId       String    @db.Uuid
  entityId        String    @db.Uuid
  text            String
  claimType       ClaimType
  sourceCitation  String?
  verifiedUntil   DateTime?
  topicTag        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  entity          Entity    @relation(fields: [entityId], references: [id], onDelete: Restrict)

  @@index([projectId, entityId])
  @@index([projectId, claimType])
}

// =============================================================================
// SIL-1 — Search Intelligence Layer: Observation Ledger
// Per docs/specs/SIL-1-OBSERVATION-LEDGER.md
// KeywordTarget: mutable governance record ("we care about this keyword")
// SERPSnapshot: immutable observation (append-only SERP capture)
// =============================================================================

model KeywordTarget {
  id         String   @id @default(uuid()) @db.Uuid

  projectId  String   @db.Uuid
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)

  query      String
  locale     String
  device     String

  isPrimary  Boolean  @default(false)

  intent     String?
  notes      String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([projectId, query, locale, device])
  @@index([projectId])
}

model SERPSnapshot {
  id                   String   @id @default(uuid()) @db.Uuid

  projectId            String   @db.Uuid
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)

  query                String
  locale               String
  device               String

  capturedAt           DateTime
  validAt              DateTime?

  rawPayload           Json
  payloadSchemaVersion String?

  aiOverviewStatus     String   // Application-validated: "present" | "absent" | "parse_error"
  aiOverviewText       String?

  source               String
  batchRef             String?

  createdAt            DateTime @default(now())

  @@unique([projectId, query, locale, device, capturedAt])
  @@index([projectId, query, locale, device, capturedAt])
  @@index([projectId])
}

// =============================================================================
// System Config — from DB-ARCHITECTURE-PLAN.md
// Intentionally NOT project-scoped. Global system configuration.
// Per-project overrides use JSON value: { "default": N, "overrides": { "<projectId>": N } }
// =============================================================================

model SystemConfig {
  id        String    @id @default(uuid()) @db.Uuid
  key       String    @unique
  value     Json
  updatedBy ActorType
  updatedAt DateTime  @updatedAt
}

// =============================================================================
// Content Graph Phase 1 — Core structural registration layer
// Per docs/specs/CONTENT-GRAPH-DATA-MODEL.md, docs/specs/CONTENT-GRAPH-PHASES.md
// Phase 1 scope: Surface, Site, Page, ContentArchetype, Topic, Entity,
//                PageTopic, PageEntity, InternalLink, SchemaUsage
// Intelligence is compute-on-read only. No materialized scores.
// =============================================================================

// CgSurface — A brand surface where content exists (website, wiki, blog, X, YouTube)
// key: canonicalized operator/admin identifier (lowercase, hyphens only)
// canonicalIdentifier: durable machine-readable platform identity
//   website  → normalized host, e.g. "psymetric.io"
//   youtube  → channel ID or normalized slug, e.g. "UCxxxxxx" or "@psymetric"
//   x        → normalized handle without @, e.g. "psymetric"
//   wiki/blog → normalized host or slug
// canonicalUrl: optional human-facing reference URL (presentation layer)
// Uniqueness: (projectId, key) for operator identity;
//             (projectId, type, canonicalIdentifier) for platform identity
//             — enforced via partial unique index in migration (canonicalIdentifier IS NOT NULL)
model CgSurface {
  id                  String        @id @default(uuid()) @db.Uuid
  projectId           String        @db.Uuid
  project             Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  type                CgSurfaceType
  key                 String        // Canonicalized operator identifier: lowercase a-z0-9 + hyphens
  label               String?
  canonicalIdentifier String?       // Durable machine-readable platform identity (see comments above)
  canonicalUrl        String?       // Optional presentation/reference URL
  enabled             Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  sites               CgSite[]

  @@unique([projectId, key])
  @@index([projectId, type])
  // Note: partial unique index on (projectId, type, canonicalIdentifier) WHERE canonicalIdentifier IS NOT NULL
  // is enforced via raw migration SQL — not expressible as Prisma @@unique with partial filter.
}

// CgSite — A web property within a surface
model CgSite {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @db.Uuid
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  surfaceId   String    @db.Uuid
  surface     CgSurface @relation(fields: [surfaceId], references: [id], onDelete: Restrict)
  domain      String
  framework   String?   // e.g. "nextjs", "wordpress"
  isCanonical Boolean   @default(true)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  pages       CgPage[]

  @@unique([projectId, domain])
  @@index([projectId, surfaceId])
}

// CgContentArchetype — Structural page type (guide, comparison, review, tutorial, reference)
model CgContentArchetype {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  key       String   // Stable short identifier, e.g. "guide", "comparison"
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pages     CgPage[]

  @@unique([projectId, key])
  @@index([projectId])
}

// CgPage — A canonical content unit on a site
model CgPage {
  id                  String              @id @default(uuid()) @db.Uuid
  projectId           String              @db.Uuid
  project             Project             @relation(fields: [projectId], references: [id], onDelete: Restrict)
  siteId              String              @db.Uuid
  site                CgSite              @relation(fields: [siteId], references: [id], onDelete: Restrict)
  contentArchetypeId  String?             @db.Uuid
  contentArchetype    CgContentArchetype? @relation(fields: [contentArchetypeId], references: [id], onDelete: SetNull)
  url                 String
  title               String
  canonicalUrl        String?
  publishingState     CgPublishingState   @default(draft)
  isIndexable         Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  pageTopics          CgPageTopic[]
  pageEntities        CgPageEntity[]
  outboundLinks       CgInternalLink[]    @relation("InternalLinkSource")
  inboundLinks        CgInternalLink[]    @relation("InternalLinkTarget")
  schemaUsages        CgSchemaUsage[]

  @@unique([projectId, url])
  @@index([projectId, siteId, publishingState])
}

// CgTopic — Conceptual territory cluster
model CgTopic {
  id        String      @id @default(uuid()) @db.Uuid
  projectId String      @db.Uuid
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Restrict)
  key       String      // Stable short identifier
  label     String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  pageTopics CgPageTopic[]

  @@unique([projectId, key])
  @@index([projectId])
}

// CgEntity — Real-world entity referenced by content (product, technology, concept, etc.)
model CgEntity {
  id          String        @id @default(uuid()) @db.Uuid
  projectId   String        @db.Uuid
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  key         String        // Stable short identifier
  label       String
  entityType  String        // e.g. "product", "technology", "concept", "organization"
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  pageEntities CgPageEntity[]

  @@unique([projectId, key])
  @@index([projectId, entityType])
}

// CgPageTopic — Junction: page ↔ topic
model CgPageTopic {
  id        String      @id @default(uuid()) @db.Uuid
  projectId String      @db.Uuid
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Restrict)
  pageId    String      @db.Uuid
  page      CgPage      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  topicId   String      @db.Uuid
  topic     CgTopic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  role      CgPageRole  @default(supporting)
  createdAt DateTime    @default(now())

  @@unique([pageId, topicId])
  @@index([projectId, topicId])
}

// CgPageEntity — Junction: page ↔ entity
model CgPageEntity {
  id        String      @id @default(uuid()) @db.Uuid
  projectId String      @db.Uuid
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Restrict)
  pageId    String      @db.Uuid
  page      CgPage      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  entityId  String      @db.Uuid
  entity    CgEntity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  role      CgPageRole  @default(supporting)
  createdAt DateTime    @default(now())

  @@unique([pageId, entityId])
  @@index([projectId, entityId])
}

// CgInternalLink — Structural link between two pages
model CgInternalLink {
  id             String     @id @default(uuid()) @db.Uuid
  projectId      String     @db.Uuid
  project        Project    @relation(fields: [projectId], references: [id], onDelete: Restrict)
  sourcePageId   String     @db.Uuid
  sourcePage     CgPage     @relation("InternalLinkSource", fields: [sourcePageId], references: [id], onDelete: Cascade)
  targetPageId   String     @db.Uuid
  targetPage     CgPage     @relation("InternalLinkTarget", fields: [targetPageId], references: [id], onDelete: Cascade)
  anchorText     String?
  linkRole       CgLinkRole @default(support)
  createdAt      DateTime   @default(now())

  @@unique([sourcePageId, targetPageId])
  @@index([projectId, sourcePageId])
  @@index([projectId, targetPageId])
}

// CgSchemaUsage — Structured data used on a page (Article, Product, FAQ, HowTo, Recipe, etc.)
model CgSchemaUsage {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  pageId      String   @db.Uuid
  page        CgPage   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  schemaType  String   // e.g. "Article", "Product", "FAQ", "HowTo", "Recipe"
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([pageId, schemaType])
  @@index([projectId, schemaType])
  @@index([projectId, pageId])
}
