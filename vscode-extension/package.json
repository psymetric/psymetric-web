{
  "name": "veda-vscode",
  "displayName": "VEDA Observatory",
  "description": "VEDA SEO observatory command center for VS Code",
  "version": "0.1.0",
  "publisher": "veda",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:veda.switchEnvironment",
    "onCommand:veda.selectProject",
    "onCommand:veda.refreshContext",
    "onCommand:veda.investigateProject",
    "onCommand:veda.keywordDiagnostic",
    "onCommand:veda.investigateCurrentPage",
    "onCommand:veda.pageKeywordDiagnostic",
    "onCommand:veda.riskKeywordFromPageContext",
    "onCommand:veda.refreshEditorContext",
    "onCommand:veda.refreshSummary",
    "onCommand:veda.refreshAlerts",
    "onCommand:veda.refreshKeywords",
    "onView:veda.projectContext",
    "onView:veda.editorContext",
    "onView:veda.investigationSummary",
    "onView:veda.topAlerts",
    "onView:veda.keywords",
    "onView:veda.recentPageWorkflow",
    "onCommand:veda.replayWorkflowEntry",
    "onCommand:veda.summaryKeywordDiagnostic"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "veda.switchEnvironment",
        "title": "VEDA: Switch Environment"
      },
      {
        "command": "veda.selectProject",
        "title": "VEDA: Select Project"
      },
      {
        "command": "veda.refreshContext",
        "title": "VEDA: Refresh Context"
      },
      {
        "command": "veda.investigateProject",
        "title": "VEDA: Investigate Project"
      },
      {
        "command": "veda.keywordDiagnostic",
        "title": "VEDA: Keyword Diagnostic"
      },
      {
        "command": "veda.investigateCurrentPage",
        "title": "VEDA: Investigate Current Page Context",
        "icon": "$(search)"
      },
      {
        "command": "veda.pageKeywordDiagnostic",
        "title": "VEDA: Choose Project Keyword Diagnostic"
      },
      {
        "command": "veda.riskKeywordFromPageContext",
        "title": "VEDA: Risk Keyword Diagnostic from Page Context"
      },
      {
        "command": "veda.refreshEditorContext",
        "title": "VEDA: Refresh Editor Context",
        "icon": "$(refresh)"
      },
      {
        "command": "veda.refreshSummary",
        "title": "VEDA: Refresh Summary",
        "icon": "$(refresh)"
      },
      {
        "command": "veda.refreshAlerts",
        "title": "VEDA: Refresh Alerts",
        "icon": "$(refresh)"
      },
      {
        "command": "veda.refreshKeywords",
        "title": "VEDA: Refresh Keywords",
        "icon": "$(refresh)"
      },
      {
        "command": "veda.alertItemSelected",
        "title": "VEDA: Open Alert Detail"
      },
      {
        "command": "veda.keywordItemSelected",
        "title": "VEDA: Keyword Item Diagnostic"
      },
      {
        "command": "veda.replayWorkflowEntry",
        "title": "VEDA: Replay Workflow Entry"
      },
      {
        "command": "veda.summaryKeywordDiagnostic",
        "title": "VEDA: Summary Keyword Diagnostic"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "veda",
          "title": "VEDA",
          "icon": "$(telescope)"
        }
      ]
    },
    "views": {
      "veda": [
        {
          "id": "veda.projectContext",
          "name": "Project Context",
          "type": "webview"
        },
        {
          "id": "veda.editorContext",
          "name": "Editor Context",
          "type": "webview"
        },
        {
          "id": "veda.investigationSummary",
          "name": "Investigation Summary"
        },
        {
          "id": "veda.topAlerts",
          "name": "Top Alerts"
        },
        {
          "id": "veda.keywords",
          "name": "Keywords"
        },
        {
          "id": "veda.recentPageWorkflow",
          "name": "Recent Page Workflow"
        }
      ]
    },
    "configuration": {
      "title": "VEDA Observatory",
      "properties": {
        "veda.environments": {
          "type": "object",
          "default": {
            "local": { "baseUrl": "http://localhost:3000" },
            "stage": { "baseUrl": "https://stage.example.com" },
            "prod":  { "baseUrl": "https://example.com" }
          },
          "description": "VEDA environment configurations. Each key is an environment name with a baseUrl."
        },
        "veda.activeEnvironment": {
          "type": "string",
          "default": "local",
          "description": "The currently active VEDA environment."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "veda.refreshContext",
          "when": "view == veda.projectContext",
          "group": "navigation"
        },
        {
          "command": "veda.investigateCurrentPage",
          "when": "view == veda.editorContext",
          "group": "navigation"
        },
        {
          "command": "veda.refreshEditorContext",
          "when": "view == veda.editorContext",
          "group": "navigation"
        },
        {
          "command": "veda.refreshSummary",
          "when": "view == veda.investigationSummary",
          "group": "navigation"
        },
        {
          "command": "veda.refreshAlerts",
          "when": "view == veda.topAlerts",
          "group": "navigation"
        },
        {
          "command": "veda.refreshKeywords",
          "when": "view == veda.keywords",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}
