{
  "name": "veda-vscode",
  "displayName": "VEDA Observatory",
  "description": "VEDA SEO observatory command center for VS Code",
  "version": "0.1.0",
  "publisher": "veda",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:veda.switchEnvironment",
    "onCommand:veda.selectProject",
    "onCommand:veda.refreshContext",
    "onCommand:veda.investigateProject",
    "onCommand:veda.keywordDiagnostic",
    "onView:veda.projectContext"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "veda.switchEnvironment",
        "title": "VEDA: Switch Environment"
      },
      {
        "command": "veda.selectProject",
        "title": "VEDA: Select Project"
      },
      {
        "command": "veda.refreshContext",
        "title": "VEDA: Refresh Context"
      },
      {
        "command": "veda.investigateProject",
        "title": "VEDA: Investigate Project"
      },
      {
        "command": "veda.keywordDiagnostic",
        "title": "VEDA: Keyword Diagnostic"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "veda",
          "title": "VEDA",
          "icon": "$(telescope)"
        }
      ]
    },
    "views": {
      "veda": [
        {
          "id": "veda.projectContext",
          "name": "Project Context",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "VEDA Observatory",
      "properties": {
        "veda.environments": {
          "type": "object",
          "default": {
            "local": { "baseUrl": "http://localhost:3000" },
            "stage": { "baseUrl": "https://stage.example.com" },
            "prod":  { "baseUrl": "https://example.com" }
          },
          "description": "VEDA environment configurations. Each key is an environment name with a baseUrl."
        },
        "veda.activeEnvironment": {
          "type": "string",
          "default": "local",
          "description": "The currently active VEDA environment."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "veda.refreshContext",
          "when": "view == veda.projectContext",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}
