# VEDA MCP Server Environment Configuration
# Copy this to .env for local development
#
# Preferred prefix: VEDA_*
# Legacy fallback:  PSYMETRIC_* (still accepted for backward compatibility)

# Backend API URL (required)
VEDA_BASE_URL=http://localhost:3000
# PSYMETRIC_BASE_URL=http://localhost:3000  # legacy fallback — still works

# Project Scope (exactly one required)
# Option 1: Use project UUID
VEDA_PROJECT_ID=00000000-0000-4000-a000-000000000001
# PSYMETRIC_PROJECT_ID=00000000-0000-4000-a000-000000000001  # legacy fallback

# Option 2: Use project slug (comment out PROJECT_ID if using this)
# VEDA_PROJECT_SLUG=your-project-slug
# PSYMETRIC_PROJECT_SLUG=your-project-slug  # legacy fallback

# HTTP timeout in milliseconds (optional, default: 30000)
VEDA_TIMEOUT_MS=30000
# PSYMETRIC_TIMEOUT_MS=30000  # legacy fallback
